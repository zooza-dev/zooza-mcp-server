# Copy to .env and fill in values. .env is gitignored.

# Port the MCP HTTP server listens on inside the container.
PORT=3001

# Base URL of the Zooza API.
# - Inside docker-compose: http://php-server/v1
# - From the host: http://localhost:8080/v1
ZOOZA_API_BASE=http://php-server/v1

# --- Auth mode ---------------------------------------------------------------
# Default false (production). When true, the server accepts requests with
# no Authorization header and uses the legacy ZOOZA_API_TOKEN / ZOOZA_API_COMPANY
# below. When a Bearer header IS present the JWT is always validated — no
# silent fallback either way.
ZOOZA_ALLOW_HARDCODED_AUTH=true

# --- Server-wide credentials (always required) -------------------------------
# Identifies "the MCP integration" to api-v1. Same value for every user/company.
ZOOZA_API_KEY=as43gjrvnr597

# --- Dev-fallback credentials (only used when ZOOZA_ALLOW_HARDCODED_AUTH=true
#     AND no Authorization header is present) ---------------------------------
ZOOZA_API_TOKEN=replace-me
ZOOZA_API_COMPANY=1

# --- OAuth resource + auth-server URLs ---------------------------------------
# Required when ZOOZA_ALLOW_HARDCODED_AUTH=false. The auth server's JWKS is
# expected at {MCP_AUTH_SERVER_URL}/.well-known/jwks.json.
MCP_RESOURCE_URL=http://localhost:3001/mcp
MCP_AUTH_SERVER_URL=http://localhost:3000

# Optional. Cache TTL for the auth server's JWKS. Default 3600s.
# MCP_JWKS_CACHE_TTL_SECONDS=3600

# Optional. Flip to true once zooza-auth starts issuing `aud` claim. Default false.
# MCP_REQUIRE_AUD=false

# --- Terminology auto-sync ---------------------------------------------------
# Optional. Set to a GitHub Personal Access Token with read:contents on zooza-dev/sdd-workflow.
# When set, `npm run compile:terminology` (called automatically from `npm run build`)
# fetches the latest translations/terminology.yml from the canonical master repo (sdd-workflow)
# before compiling. Without this token, the committed src/terminology/terminology.yml is used.
# Source of truth: zooza-dev/sdd-workflow → translations/terminology.yml
# HELP_REPO_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- Misc --------------------------------------------------------------------
# Set to "true" to force the local /events/preview stub (until api-v1's endpoint ships).
# Remove the line once the real endpoint is deployed.
# EVENTS_PREVIEW_USE_STUB=true
